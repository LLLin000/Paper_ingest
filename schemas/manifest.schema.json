{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schemas/manifest.schema.json",
  "title": "Run Manifest",
  "type": "object",
  "required": [
    "doc_id",
    "input_pdf_path",
    "input_pdf_sha256",
    "started_at_utc",
    "toolchain",
    "model_config",
    "render_config",
    "pipeline_version"
  ],
  "properties": {
    "doc_id": {
      "type": "string",
      "description": "Unique document identifier"
    },
    "input_pdf_path": {
      "type": "string",
      "description": "Path to input PDF file"
    },
    "input_pdf_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA256 hash of input PDF"
    },
    "started_at_utc": {
      "type": "string",
      "format": "date-time",
      "description": "Pipeline start timestamp in ISO 8601 format"
    },
    "toolchain": {
      "type": "object",
      "required": ["python_version", "package_lock_hash"],
      "properties": {
        "python_version": {
          "type": "string"
        },
        "package_lock_hash": {
          "type": "string"
        }
      }
    },
    "model_config": {
      "type": "object",
      "required": ["text_model", "vision_model", "temperature"],
      "properties": {
        "text_model": {
          "type": "string"
        },
        "vision_model": {
          "type": "string"
        },
        "vision_provider": {
          "type": "string"
        },
        "reading_provider": {
          "type": "string"
        },
        "reading_model": {
          "type": "string"
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        },
        "prompt_bundle_version": {
          "type": "string"
        }
      }
    },
    "render_config": {
      "type": "object",
      "required": ["dpi", "scale"],
      "properties": {
        "dpi": {
          "type": "integer",
          "minimum": 72
        },
        "scale": {
          "type": "number",
          "minimum": 0.1
        }
      }
    },
    "pipeline_version": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
